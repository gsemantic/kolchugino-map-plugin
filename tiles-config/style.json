{
  "version": 8,
  "name": "Kolchugino Bright Style",
  "sources": {
    "openstreetmap": {
      "type": "vector",
      "url": "https://tile.openstreetmap.org/data/v1/tiles.json"
    },
    "boundaries": {
      "type": "geojson",
      "data": "./data/boundaries/kolchugino_district.geojson"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#b8d4e8"
      }
    },
    {
      "id": "district-boundary",
      "type": "fill",
      "source": "boundaries",
      "paint": {
        "fill-color": "#ffffff",
        "fill-opacity": 0.9
      }
    },
    {
      "id": "district-outline",
      "type": "line",
      "source": "boundaries",
      "paint": {
        "line-color": "#2c3e50",
        "line-width": 2,
        "line-dasharray": [2, 1]
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openstreetmap",
      "source-layer": "water",
      "paint": {
        "fill-color": "#3498db",
        "fill-pattern": "waves"
      }
    },
    {
      "id": "landuse-forest",
      "type": "fill",
      "source": "openstreetmap",
      "source-layer": "landuse",
      "filter": ["==", "class", "wood"],
      "paint": {
        "fill-color": "#27ae60",
        "fill-pattern": "trees"
      }
    },
    {
      "id": "landuse-park",
      "type": "fill",
      "source": "openstreetmap",
      "source-layer": "landuse",
      "filter": ["in", "class", "park", "grass"],
      "paint": {
        "fill-color": "#2ecc71"
      }
    },
    {
      "id": "roads",
      "type": "line",
      "source": "openstreetmap",
      "source-layer": "transportation",
      "paint": {
        "line-color": "#f39c12",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          10, 1,
          14, 4,
          18, 12
        ]
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "openstreetmap",
      "source-layer": "building",
      "paint": {
        "fill-color": "#e74c3c",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "openstreetmap",
      "source-layer": "place",
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": 14
      },
      "paint": {
        "text-color": "#2c3e50",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    }
  ],
  "sprite": "https://openmaptiles.org/styles/sprites/bright",
  "glyphs": "https://openmaptiles.org/fonts/{fontstack}/{range}.pbf"
}
